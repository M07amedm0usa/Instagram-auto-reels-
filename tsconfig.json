{
  "compilerOptions": {
    "target":           "ES2020",
    "module":           "ESNext",
    "moduleResolution": "Bundler",
    "jsx":              "react-jsx",
    "strict":           true,
    "esModuleInterop":  true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "outDir":           "./dist",
    "baseUrl":          ".",
    "paths": {}
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}

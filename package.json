{
  "name": "flutter-reel-factory",
  "version": "3.0.0",
  "description": "Automated Flutter widget video generator for Instagram Reels — @flutterbymousa",
  "scripts": {
    "start":   "remotion studio",
    "preview": "remotion studio",
    "build":   "remotion render FlutterLesson out/lesson.mp4 --gl=swiftshader",
    "render":  "remotion render FlutterLesson --gl=swiftshader"
  },
  "dependencies": {
    "@remotion/cli": "4.0.230",
    "remotion":      "4.0.230",
    "react":         "18.3.1",
    "react-dom":     "18.3.1"
  },
  "devDependencies": {
    "@types/react":     "18.3.1",
    "@types/react-dom": "18.3.1",
    "typescript":       "5.5.4"
  },
  "remotion": {
    "entryPoint": "src/index.ts"
  }
}

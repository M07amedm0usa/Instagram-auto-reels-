{
  "intro": {
    "tag": "FLUTTER BASICS",
    "number": "01",
    "title": "<span>Text</span> Widget",
    "subtitle": "ازاي تعرض نص في التطبيق",
    "props": [
      { "text": "Text",      "type": "ip-kw" },
      { "text": "TextStyle", "type": "ip-ty" },
      { "text": "fontSize",  "type": "ip-nm" },
      { "text": "bold",      "type": "ip-mt" }
    ]
  },
  "outro": {
    "title": "جرب الكود<br/>بنفسك!",
    "doc": "flutter.dev/docs",
    "next": "<span>↩</span><span>الجزء الجاي: Container</span>"
  },
  "script": [
    { "sync": 500 },
    { "type": "Text()" },
    { "move": -1 },
    { "enter": 2 },
    { "error": "'مرحي'", "fix": "'مرحباً بالعالم',", "out": { "text": "مرحباً بالعالم" } },
    { "callout": "النص المعروض" },
    { "sync": 3500 },
    { "enter": 2 },
    { "type": "style: TextStyle()" },
    { "move": -1 },
    { "enter": 4 },
    { "type": "fontSize: 24,", "out": { "fs": 24 } },
    { "callout": "حجم الخط" },
    { "wait": 400 },
    { "enter": 4 },
    { "type": "fontWeight: FontWeight.bold,", "out": { "fw": 700 } },
    { "callout": "سُمك الخط" },
    { "wait": 400 },
    { "enter": 4 },
    { "type": "color: Colors.deepPurple,", "out": { "color": "#7c3aed" } }
  ]
}
